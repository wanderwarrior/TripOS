DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tripcraft?schema=public"
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"

# --- WhatsApp Cloud API (Meta) ---
# https://developers.facebook.com/docs/whatsapp/cloud-api
# Required for outbound messages
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""

# Required for inbound webhook (GET handshake + POST signature verify)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""

# Optional — pin a specific Graph API version (defaults to v20.0)
# WHATSAPP_API_VERSION="v20.0"

# Optional — used by the phone normalizer when callers paste 10-digit
# numbers without a country code. Defaults to "91".
# WHATSAPP_DEFAULT_COUNTRY_CODE="91"

# Optional — shared secret for /api/cron/whatsapp; required in production
WHATSAPP_CRON_SECRET=""

# Optional — surfaced in trip-departure-day reminder template
WHATSAPP_OPS_PHONE="+91 90000 00000"
# Optional — surfaced in post-trip "leave a review" template
WHATSAPP_REVIEW_LINK=""

# --- Google (Sign-in + Gmail send + Drive file storage) ---
# One OAuth client for the whole app, used for BOTH "Sign in with Google" and
# the per-agency Gmail/Drive integration. Scopes are minimal & non-restricted
# (gmail.send + drive.file), so no Google CASA security review / fee is needed.
# Setup: see docs/google-integration.md
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Register BOTH authorized redirect URIs in the Google Cloud OAuth client:
#   ${NEXT_PUBLIC_APP_URL}/api/auth/callback/google         # Sign in with Google
#   ${NEXT_PUBLIC_APP_URL}/api/integrations/google/callback # Gmail/Drive connect
# (leave GOOGLE_CLIENT_ID/SECRET blank to hide the "Sign in with Google" button)

# Encryption key for tokens/secrets at rest. If unset, falls back to
# NEXTAUTH_SECRET/AUTH_SECRET. Generate: openssl rand -base64 32
# CREDENTIALS_KEY=""

# --- Flight & Train enrichment (auto-fill segment details by number) ---
# Flights: AeroDataBox via RapidAPI (free tier). Get a key at
#   https://rapidapi.com/aedbx-aedbx/api/aerodatabox → subscribe (Basic/free).
# Server-wide fallback; agencies can set their own key in-app at
# Settings → Integrations (takes precedence).
AERODATABOX_API_KEY=""
# Trains (Indian Railways) use eRail (erail.in) — keyless, no env var needed.

# Public origin (used to build proposal/invoice/voucher share links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
